distributed_type: FSDP
fsdp_config:
  fsdp_version: 2
  fsdp_auto_wrap_policy: TRANSFORMER_BASED_WRAP
  fsdp_cpu_ram_efficient_loading: false
  fsdp_offload_params: {{ cpu_offload | default(false) | lower }}
num_machines: {{ nodes }}
num_processes: {{ num_processes }}
{%- if tp > 1 or cp > 1 or pp > 1 %}
parallelism_config:
{%- if dp_shard is defined %}
  parallelism_config_dp_shard_size: {{ dp_shard }}
{%- endif %}
{%- if dp_replicate is defined %}
  parallelism_config_dp_replicate_size: {{ dp_replicate }}
{%- endif %}
{%- if tp > 1 %}
  parallelism_config_tp_size: {{ tp }}
{%- endif %}
{%- if cp > 1 %}
  parallelism_config_cp_size: {{ cp }}
{%- endif %}
{%- if pp > 1 %}
  parallelism_config_pp_size: {{ pp }}
{%- endif %}
{%- endif %}
