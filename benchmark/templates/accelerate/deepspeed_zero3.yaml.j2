compute_environment: LOCAL_MACHINE
debug: false
deepspeed_config:
  deepspeed_multinode_launcher: standard
  offload_optimizer_device: {{ 'cpu' if cpu_offload else 'none' }}
  offload_param_device: {{ 'cpu' if cpu_offload else 'none' }}
  zero3_init_flag: true
  zero3_save_16bit_model: true
  zero_stage: 3
{%- if sp > 1 %}
  seq_parallel_communication_data_type: bf16
{%- endif %}
distributed_type: DEEPSPEED
downcast_bf16: 'no'
machine_rank: 0
main_training_function: main
mixed_precision: bf16
num_machines: {{ nodes }}
num_processes: {{ num_processes }}
rdzv_backend: static
same_network: true
tpu_env: []
tpu_use_cluster: false
tpu_use_sudo: false
use_cpu: false
{%- if sp > 1 or tp > 1 %}
parallelism_config:
{%- if dp_shard is defined %}
  parallelism_config_dp_shard_size: {{ dp_shard }}
{%- endif %}
{%- if dp_replicate is defined %}
  parallelism_config_dp_replicate_size: {{ dp_replicate }}
{%- endif %}
{%- if tp > 1 %}
  parallelism_config_tp_size: {{ tp }}
{%- endif %}
{%- if sp > 1 %}
  parallelism_config_sp_size: {{ sp }}
  parallelism_config_sp_backend: deepspeed
  parallelism_config_sp_seq_length_is_variable: true
  parallelism_config_sp_attn_implementation: {{ sp_attn_implementation | default('flash_attention_2') }}
{%- endif %}
{%- endif %}
