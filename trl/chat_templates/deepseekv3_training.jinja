{#- Training variant of the DeepSeek-V3 chat template (see deepseekv3.jinja for the original).
    Modifications vs the original:
    - Added {% generation %} / {% endgeneration %} around assistant message output to support
      assistant-only loss masking in SFT training.
    - Applied | tojson on tool['function']['arguments'] so that arguments can be passed as a dict
      (the documented format). The original uses raw string concatenation, which crashes on dicts.
-#}
{% if not add_generation_prompt is defined %}{% set add_generation_prompt = false %}{% endif %}{% set ns = namespace(is_first=false, is_tool=false, is_output_first=true, system_prompt='', is_first_sp=true) %}{%- for message in messages %}{%- if message['role'] == 'system' %}{%- if ns.is_first_sp %}{% set ns.system_prompt = ns.system_prompt + message['content'] %}{% set ns.is_first_sp = false %}{%- else %}{% set ns.system_prompt = ns.system_prompt + '\n\n' + message['content'] %}{%- endif %}{%- endif %}{%- endfor %}{{ bos_token }}{{ ns.system_prompt }}{%- for message in messages %}{%- if message['role'] == 'user' %}{%- set ns.is_tool = false -%}{{'<пљЬUserпљЬ>' + message['content']}}{%- endif %}{%- if message['role'] == 'assistant' and 'tool_calls' in message %}{%- set ns.is_tool = false -%}{%- generation %}{%- for tool in message['tool_calls'] %}{%- if not ns.is_first %}{%- if message['content'] is none %}{{'<пљЬAssistantпљЬ><пљЬtoolвЦБcallsвЦБbeginпљЬ><пљЬtoolвЦБcallвЦБbeginпљЬ>' + tool['type'] + '<пљЬtoolвЦБsepпљЬ>' + tool['function']['name'] + '\n' + '```json' + '\n' + tool['function']['arguments'] | tojson + '\n' + '```' + '<пљЬtoolвЦБcallвЦБendпљЬ>'}}{%- else %}{{'<пљЬAssistantпљЬ>' + message['content'] + '<пљЬtoolвЦБcallsвЦБbeginпљЬ><пљЬtoolвЦБcallвЦБbeginпљЬ>' + tool['type'] + '<пљЬtoolвЦБsepпљЬ>' + tool['function']['name'] + '\n' + '```json' + '\n' + tool['function']['arguments'] | tojson + '\n' + '```' + '<пљЬtoolвЦБcallвЦБendпљЬ>'}}{%- endif %}{%- set ns.is_first = true -%}{%- else %}{{'\n' + '<пљЬtoolвЦБcallвЦБbeginпљЬ>' + tool['type'] + '<пљЬtoolвЦБsepпљЬ>' + tool['function']['name'] + '\n' + '```json' + '\n' + tool['function']['arguments'] | tojson + '\n' + '```' + '<пљЬtoolвЦБcallвЦБendпљЬ>'}}{%- endif %}{%- endfor %}{{'<пљЬtoolвЦБcallsвЦБendпљЬ><пљЬendвЦБofвЦБsentenceпљЬ>'}}{%- endgeneration %}{%- endif %}{%- if message['role'] == 'assistant' and 'tool_calls' not in message %}{%- if ns.is_tool %}{%- generation %}{{'<пљЬtoolвЦБoutputsвЦБendпљЬ>' + message['content'] + '<пљЬendвЦБofвЦБsentenceпљЬ>'}}{%- set ns.is_tool = false -%}{%- endgeneration %}{%- else %}{%- generation %}{% set content = message['content'] %}{% if '</think>' in content %}{% set content = content.split('</think>')[-1] %}{% endif %}{{'<пљЬAssistantпљЬ>' + content + '<пљЬendвЦБofвЦБsentenceпљЬ>'}}{%- endgeneration %}{%- endif %}{%- endif %}{%- if message['role'] == 'tool' %}{%- set ns.is_tool = true -%}{%- if ns.is_output_first %}{{'<пљЬtoolвЦБoutputsвЦБbeginпљЬ><пљЬtoolвЦБoutputвЦБbeginпљЬ>' + message['content'] + '<пљЬtoolвЦБoutputвЦБendпљЬ>'}}{%- set ns.is_output_first = false %}{%- else %}{{'<пљЬtoolвЦБoutputвЦБbeginпљЬ>' + message['content'] + '<пљЬtoolвЦБoutputвЦБendпљЬ>'}}{%- endif %}{%- endif %}{%- endfor -%}{% if ns.is_tool %}{{'<пљЬtoolвЦБoutputsвЦБendпљЬ>'}}{% endif %}{% if add_generation_prompt and not ns.is_tool %}{{'<пљЬAssistantпљЬ><think>\n'}}{% endif %}